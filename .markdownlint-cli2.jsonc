{
  // Options for markdownlint-cli2 (rules live in .markdownlint.jsonc).
  // Templater templates start with a <%* tag, which breaks standard
  // markdown parsing; they are code, not prose, so they are not linted.
  // CHANGELOG.md is generated by release-please; its output format is
  // not ours to lint and kept the Lint workflow red since v1.0.0.
  "ignores": [
    "System/Templates/**",
    "node_modules/**",
    "CHANGELOG.md"
  ]
}
